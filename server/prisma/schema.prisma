generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  COACH
  PATIENT
}

enum Gender {
  MALE
  FEMALE
}

enum NotificationType {
  SYSTEM
  INDIVIDUAL
}

enum SessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum PackageStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  COMPLETED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum TransactionType {
  ASSESSMENT
  PACKAGE
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(PATIENT)
  gender       Gender   @default(MALE)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  patientProfile PatientProfile?
  coachProfile   CoachProfile?

  messagesSent     Message[]      @relation("SentMessages")
  messagesReceived Message[]      @relation("ReceivedMessages")
  notifications    Notification[] @relation("UserNotifications")
  transactions     Transaction[]  @relation("UserTransactions")
}

model PatientProfile {
  id              String        @id @default(uuid())
  userId          String        @unique
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  gender          Gender        @default(MALE)
  dateOfBirth     DateTime?
  medicalHistory  String?
  notes           String?
  assignedCoachId String?
  assignedCoach   CoachProfile? @relation("AssignedCoach", fields: [assignedCoachId], references: [id], onDelete: SetNull)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  patientPackages PatientPackage[]
  painLogs        PainLog[]
  assessmentForms AssessmentForm[]
}

model CoachProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialties    String[]
  bio            String?
  commissionRate Float    @default(0.0) // E.g., 0.20 for 20%
  isApproved     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sessions Session[]
  patients PatientProfile[] @relation("AssignedCoach")
}

model Package {
  id               String   @id @default(uuid())
  name             String
  description      String?
  price            Float
  numberOfSessions Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  patientPackages PatientPackage[]
}

model PatientPackage {
  id                String         @id @default(uuid())
  patientProfileId  String
  patientProfile    PatientProfile @relation(fields: [patientProfileId], references: [id], onDelete: Cascade)
  packageId         String
  package           Package        @relation(fields: [packageId], references: [id], onDelete: Restrict)
  status            PackageStatus  @default(ACTIVE)
  remainingSessions Int
  startDate         DateTime       @default(now())
  endDate           DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  sessions     Session[]
  transactions Transaction[]
}

model Session {
  id               String         @id @default(uuid())
  patientPackageId String
  patientPackage   PatientPackage @relation(fields: [patientPackageId], references: [id], onDelete: Cascade)
  coachProfileId   String
  coachProfile     CoachProfile   @relation(fields: [coachProfileId], references: [id], onDelete: Restrict)
  scheduledAt      DateTime
  status           SessionStatus  @default(SCHEDULED)
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  transaction Transaction?
}

model Transaction {
  id                String            @id @default(uuid())
  userId            String?
  user              User?             @relation("UserTransactions", fields: [userId], references: [id], onDelete: SetNull)
  patientPackageId  String?
  patientPackage    PatientPackage?   @relation(fields: [patientPackageId], references: [id], onDelete: Cascade)
  sessionId         String?           @unique
  session           Session?          @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  assessmentFormId  String?
  assessmentForm    AssessmentForm?   @relation(fields: [assessmentFormId], references: [id], onDelete: SetNull)
  amount            Float // Final amount paid
  baseAmount        Float? // Amount before discount
  commissionAmount  Float? // Fixed amount per package/session as per requirements
  zarinpalAuthority String? // Added Zarinpal authority field
  zarinpalRefId     String? // Added Zarinpal refId field
  status            TransactionStatus @default(PENDING)
  type              TransactionType   @default(PACKAGE)
  discountCodeId    String?
  discountCode      DiscountCode?     @relation(fields: [discountCodeId], references: [id], onDelete: SetNull)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model DiscountCode {
  id             String       @id @default(uuid())
  code           String       @unique
  type           DiscountType
  value          Float // Percentage or fixed amount
  expirationDate DateTime?
  maxUses        Int?
  usedCount      Int          @default(0)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  transactions Transaction[]
}

model Message {
  id            String   @id @default(uuid())
  senderId      String
  sender        User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId    String
  receiver      User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  content       String
  attachmentUrl String? // Added support for attachments via S3
  read          Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PainLog {
  id               String         @id @default(uuid())
  patientProfileId String
  patientProfile   PatientProfile @relation(fields: [patientProfileId], references: [id], onDelete: Cascade)
  painLevel        Int // 1-10 scale
  bodyLocation     String
  notes            String?
  loggedAt         DateTime       @default(now())
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model AssessmentForm {
  id             String   @id @default(uuid())
  fullName       String
  phone          String
  age            Int
  gender         Gender   @default(MALE)
  sport          String
  selectedZone   String
  painIntensity  Int
  history        String
  goals          String
  mediaUrls      String[]
  assessmentPaid Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Once approved or finalized, it can be linked to a patient profile
  patientProfileId String?
  patientProfile   PatientProfile? @relation(fields: [patientProfileId], references: [id], onDelete: SetNull)

  transactions Transaction[]
}

model Notification {
  id        String           @id @default(uuid())
  title     String
  content   String
  type      NotificationType @default(SYSTEM)
  userId    String?
  user      User?            @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
}
